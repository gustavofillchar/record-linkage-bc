{
    "compilerOptions": {
        "target": "ES2023",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "noUncheckedIndexedAccess": true,
        "noEmit": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "src",
        "tests",
        "vitest.config.ts"
    ]
}